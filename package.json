{
  "name": "orbit-x",
  "version": "1.0.0",
  "description": "ORBIT-X - Autonomous Satellite Monitoring & AI Command Console",
  "main": "main.js",
  "scripts": {
    "start": "node launch.js",
    "serve": "node server.js",
    "dist": "electron-builder -w"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "mqtt": "^5.0.0",
    "node-adodb": "^5.0.3",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "cross-env": "^10.1.0",
    "electron": "^40.8.5",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.2"
  },
  "build": {
    "appId": "com.orbitx.dashboard",
    "productName": "Orbit-X",
    "artifactName": "Orbit-X.${ext}",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false
    },
    "mac": {
      "identity": null
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-adodb/**/*",
      "ai_service/**/*"
    ]
  },
  "author": "",
  "license": "ISC"
}
